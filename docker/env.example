# Mechanical connection settings
# Use 'mechanical' to connect to the Mechanical container service
# Use 'host.docker.internal' to connect to Mechanical on host (Windows/Mac)
# Use 'localhost' with network_mode: host (Linux)
PYMECHANICAL_IP=mechanical
PYMECHANICAL_PORT=10000

# HTTP server settings
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# gRPC transport mode for Mechanical connections.
# Accepted values: auto, insecure, mtls, wnua
#   auto     - (default) Detects mode automatically:
#              If mTLS certs are found → mtls; otherwise → insecure.
#   insecure - Plaintext gRPC (no encryption).
#   mtls     - Mutual TLS (requires ca.crt, client.crt, client.key).
#   wnua     - Windows Named User Authentication (Windows hosts only).
# Leave empty or unset for auto-detection.
# PYMECHANICAL_TRANSPORT_MODE=

# Path to mTLS certificate directory inside the container.
# Mount your host certs directory to this path.
# The directory must contain: ca.crt, client.crt, client.key
# Example: docker run -v /path/to/certs:/app/certs ...
# ANSYS_GRPC_CERTIFICATES=/app/certs

# Whether to automatically connect to Mechanical when the MCP server starts.
# When true: connection is locked (launch/connect/disconnect tools are disabled).
# When false (default): users connect dynamically via the connect_to_mechanical tool.
CONNECT_ON_STARTUP=false

# Mechanical License Server (adjust as needed)
ANSYSLMD_LICENSE_FILE=1055@license-server
